<link rel="stylesheet" href="style.css">
<style>
  .hero{padding:60px 24px 20px; max-width:1000px; margin:0 auto;}
  .trace-panel{margin-top:44px; background:var(--panel); border:1px solid var(--panel-line); border-radius:10px; padding:20px 20px 14px; overflow:hidden;}
  .trace-legend{display:flex; gap:22px; margin-bottom:6px; font-family:'JetBrains Mono', monospace; font-size:12px;}
  .trace-legend .dot{display:inline-block; width:8px; height:8px; border-radius:50%; margin-right:7px;}
  .legend-speed{color:var(--p1);} .legend-speed .dot{background:var(--p1);}
  .legend-throttle{color:var(--p2);} .legend-throttle .dot{background:var(--p2);}
  .legend-brake{color:var(--p3);} .legend-brake .dot{background:var(--p3);}
  svg.trace{width:100%; height:150px; display:block;}
  .trace path{fill:none; stroke-width:2; stroke-linecap:round; stroke-linejoin:round; stroke-dasharray:1400; stroke-dashoffset:1400; animation:draw 6s linear infinite;}
  @keyframes draw{0%{stroke-dashoffset:1400;} 60%{stroke-dashoffset:0;} 100%{stroke-dashoffset:-1400;}}
  @media (prefers-reduced-motion: reduce){.trace path{animation:none; stroke-dashoffset:0;}}
  .stat-row{display:flex; gap:36px; margin-top:36px; flex-wrap:wrap;}
  .stat-num{font-family:'JetBrains Mono', monospace; font-size:26px; color:var(--p1); font-weight:600;}
  .stat-label{font-family:'JetBrains Mono', monospace; font-size:11.5px; color:var(--muted); text-transform:uppercase; letter-spacing:0.08em; margin-top:4px;}
</style>
</head>
